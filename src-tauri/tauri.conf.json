{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KiMaster",
  "version": "0.1.0",
  "identifier": "com.kimaster.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KiMaster",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 680,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../bridge/kimaster_plugin": "bridge/kimaster_plugin"
    }
  }
}
